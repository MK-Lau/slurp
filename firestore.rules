rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Slurps ────────────────────────────────────────────────────────────────
    // All writes go through the Admin SDK (server-side), so client writes are
    // denied entirely. Reads are allowed only to participants matched by uid.
    match /slurps/{slurpId} {
      // All reads are served through the API (Admin SDK); direct client reads
      // and writes are blocked entirely.
      allow read: if false;
      allow write: if false;
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    // Each user can only read/write their own profile document.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
