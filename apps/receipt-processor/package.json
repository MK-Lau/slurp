{
  "name": "@slurp/receipt-processor",
  "version": "0.1.0",
  "description": "Slurp receipt processor (Pub/Sub push subscriber)",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "node dist/apps/receipt-processor/src/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@google-cloud/firestore": "^8.0.0",
    "@google-cloud/vertexai": "^1.10.3",
    "@slurp/types": "*",
    "express": "^5.2.1",
    "google-auth-library": "^10.9.0",
    "nanoid": "^5.1.16",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.1.4",
    "tsc-alias": "^1.8.16"
  }
}
