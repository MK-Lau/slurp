# Firebase client config — set these for local dev
# In Cloud Run these are injected by Terraform as runtime env vars
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_APP_ID=
API_URL=http://localhost:8080
FIRESTORE_DATABASE=slurp-dev

# Custom domain — used in CSP and magic link trusted origins (optional)
APP_URL=
