# ── Environment ───────────────────────────────────────────────────────────────
# "dev" | "prod"
ENVIRONMENT=dev

# ── Google Cloud / Firebase ───────────────────────────────────────────────────
# GCP project ID
GCP_PROJECT_ID=your-gcp-project-id

# Firestore database name (divide-dev or divide-prod)
FIRESTORE_DATABASE=slurp-dev

# GCS bucket for receipt image uploads
RECEIPT_BUCKET=divide-receipts-dev

# Gemini API key (obtain from https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Firebase service account credentials JSON (single line, base64-encoded or raw JSON string)
# Generate via: Firebase console → Project settings → Service accounts → Generate new private key
FIREBASE_CREDENTIALS=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
