{
  "name": "@slurp/api",
  "version": "0.1.0",
  "description": "Slurp API server",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "node dist/apps/api/src/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@google-cloud/firestore": "^8.0.0",
    "@google-cloud/pubsub": "^5.0.0",
    "@google-cloud/storage": "^7.0.0",
    "@google/generative-ai": "^0.24.1",
    "@slurp/types": "*",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "firebase-admin": "^13.8.0",
    "helmet": "^8.1.0",
    "nanoid": "^5.1.7",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "tsc-alias": "^1.8.16"
  }
}
